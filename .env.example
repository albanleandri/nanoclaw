OLLAMA_HOST=

# --- OneCLI / Anthropic auth mode ---
# If you're using OneCLI for Anthropic auth, set both:
# ONECLI_URL=http://127.0.0.1:10254
# ANTHROPIC_AUTH_MODE=oauth
# or:
# ANTHROPIC_AUTH_MODE=api-key
#
# Raw Anthropic credentials can stay out of .env once OneCLI is configured.

# --- Container Secrets ---
# Variables prefixed with CONTAINER_SECRET_ are forwarded as env vars into
# agent containers. They are never committed — keep this file gitignored.
# Agents can read these values inside the container, so use them only for
# explicit opt-in cases that are not managed by OneCLI.

# Proton Calendar iCal URL (personal calendar)
# Get it from: Proton Calendar → Settings → Your calendars → [calendar] → Copy link
# CONTAINER_SECRET_PROTON_ICAL_URL=https://calendar.proton.me/api/calendar/v1/...
